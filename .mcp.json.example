{
  "mcpServers": {
    "wordpress": {
      "command": "node",
      "args": ["dist/index.js"],
      "cwd": "/path/to/mcp",
      "env": {
        "WORDPRESS_SITE_URL": "https://your-site.com",
        "WORDPRESS_API_KEY": "your-api-key-here",
        "RATE_LIMIT_PER_MINUTE": "100",
        "REQUEST_TIMEOUT": "30000"
      }
    }
  }
}
